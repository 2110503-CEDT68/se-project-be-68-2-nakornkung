        {
          "name": "Register user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "",
                  "pm.test(\"Token exists\", function () {",
                  "  pm.expect(res.token).to.exist;",
                  "});",
                  "",
                  "pm.environment.set(\"TOKEN\", res.token);",
                  "pm.collectionVariables.set(\"TOKEN\", res.token);",
                  "",
                  "// Decode JWT to extract user id",
                  "const tokenParts = res.token.split('.');",
                  "const payload = JSON.parse(atob(tokenParts[1]));",
                  "",
                  "pm.test(\"User ID exists in token\", function () {",
                  "  pm.expect(payload.id).to.exist;",
                  "});",
                  "",
                  "// Save user_id",
                  "pm.environment.set(\"user_id\", payload.id);",
                  "pm.collectionVariables.set(\"user_id\", payload.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
