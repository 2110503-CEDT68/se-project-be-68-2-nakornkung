@startuml
title Sequence Diagram: Bookings (Update)
caption Update Booking (PUT /bookings/:id) - user own / admin any

skinparam shadowing false
skinparam ParticipantPadding 18
skinparam BoxPadding 10
skinparam sequence {
  LifeLineBorderColor #6B6B6B
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #6B6B6B
  ParticipantBackgroundColor #CFE2F3
  ActorBorderColor #6B6B6B
  ArrowColor #6B6B6B
}

actor Client as client
participant ":server" as server <<javaScript>>
participant ":bookings" as bookingsRouter <<router>>
participant ":protect" as protectMw <<middleware>>
participant ":bookings" as bookingsCtrl <<controllers>>
participant ":Booking" as bookingModel <<model>>
database ":bookings" as bookingsDB <<MongoDB>>

client -> server : req.put('/api/v1/bookings/{id}')\nBearer token\nreq.body
activate server

server -> bookingsRouter : app.use('/api/v1/bookings', bookings)
activate bookingsRouter

bookingsRouter -> protectMw : protect()
activate protectMw
protectMw -> protectMw : verify JWT
protectMw --> bookingsRouter : next()
deactivate protectMw

bookingsRouter -> bookingsCtrl : updateBooking(id)
activate bookingsCtrl

bookingsCtrl -> bookingsCtrl : check ownership OR role==admin

bookingsCtrl -> bookingModel : findByIdAndUpdate(id, req.body)
activate bookingModel
bookingModel -> bookingsDB : update by _id
activate bookingsDB
bookingsDB --> bookingModel : booking
deactivate bookingsDB
bookingModel --> bookingsCtrl : booking
deactivate bookingModel

bookingsCtrl --> bookingsRouter : response (200 OK) booking
deactivate bookingsCtrl

bookingsRouter --> server : response
deactivate bookingsRouter

server --> client : response
deactivate server

@enduml
